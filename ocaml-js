#!/bin/sh

ABS_PATH ()
(
    cd -- "$(dirname -- "$1")" && printf '%s/%s\n' "$(pwd)" "$(basename -- "$1")"
)

if [ "$#" -lt 1 ]; then
    echo "Usage: $0 file1.ml [file2.ml ... main.ml]" >&2
    exit 1
fi

main_abs_path=$(ABS_PATH "${@: -1}")
target_dir=$(dirname -- "$main_abs_path")

temp_dir=$(mktemp -d "${TMPDIR:-/tmp}/tmpdir.XXXXXXXX")
if ! [ -d "$temp_dir" ]; then
    echo "Failed to create temporary directory" >&2
    exit 1
fi
trap 'rm -rf "$temp_dir"' EXIT INT TERM

new_sources=""
for src in "$@"; do
    abs_src=$(ABS_PATH "$src")
    if ! [ -f "$abs_src" ]; then
        echo "No source file: $abs_src" >&2
        exit 1
    fi

    if ! command cp -f "$abs_src" "$temp_dir"; then
        echo "Failed to copy source file: $abs_src" >&2
        exit 1
    fi
    
    filename=$(basename -- "$abs_src")
    new_sources="$new_sources $temp_dir/$filename"

    # Last OCaml file is main.ml    
    main_target="$temp_dir/$filename"
done

byte_output="${main_target%.ml}.byte"

if ! ocamlfind ocamlc -package js_of_ocaml -package js_of_ocaml-ppx -linkpkg -o "$byte_output" $new_sources; then
    echo "OCaml compilation failed" >&2
    exit 1
fi

if ! js_of_ocaml "$byte_output"; then
    echo "js_of_ocaml conversion failed" >&2
    exit 1
fi

js_output="${byte_output%.byte}.js"
if ! command mv -f "$js_output" "$target_dir"; then
    echo "Failed to move compiled JS file to $target_dir" >&2
    exit 1
fi

echo "Successfully compiled to $target_dir/$(basename -- "$js_output")"
